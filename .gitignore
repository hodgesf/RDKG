# ===============================
# Python
# ===============================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# Virtual environments
venv/
.env/
.venv/
env/

# ===============================
# OS Files
# ===============================
.DS_Store
Thumbs.db

# ===============================
# IDE / Editor
# ===============================
.vscode/
.idea/
*.swp
*.swo

# ===============================
# Logs
# ===============================
*.log

# ===============================
# Snakemake
# ===============================
.snakemake/
snakemake.log

# ===============================
# Downloaded / Raw Data
# ===============================
owl_files/*
!owl_files/.gitkeep

# ===============================
# Graph Data (IMPORTANT)
# ===============================

# ignore top-level generated graph files
files/*.jsonl

# ignore per-source node/edge files
files/*/*.jsonl

# (optional) ignore nested data dir if used
files/data/*/*.jsonl

# ===============================
# Generated Graph Outputs
# ===============================
jsonl/*
!jsonl/.gitkeep

# ===============================
# Build / Temporary Files
# ===============================
tmp/
temp/
build/

# ===============================
# Packaging
# ===============================
dist/
*.egg-info/

# ===============================
# Cache
# ===============================
.cache/
.ipynb_checkpoints/
